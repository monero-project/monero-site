---
export const prerender = true;

import BlogContent from "@/components/pages/blog/BlogContent.astro";
import BlogHeader from "@/components/pages/blog/BlogHeader.astro";
import Card from "@/components/ui/Card.astro";
import Layout from "@/layouts/Layout.astro";
import { defaultLocale } from "@/i18n/config";
import { getDirection, getLocalizedEntry, splitLocaleId } from "@/i18n/utils";
import { getDateStringFromId, getLocalizedBlog } from "@/utils/blog";
import type { GetStaticPaths } from "astro";
import { Image } from "astro:assets";
import { render } from "astro:content";

export const getStaticPaths: GetStaticPaths = async () => {
  const posts = await getLocalizedBlog(defaultLocale);
  return posts.map((post) => {
    const { slug } = splitLocaleId(post.id);
    return { params: { post: slug }, props: { slug } };
  });
};

interface Props {
  slug: string;
}

const { slug } = Astro.props;
const { locale, t, localizeHref, localizeDateString } = Astro.locals;

const post = await getLocalizedEntry("blog", locale, slug);
if (!post) {
  throw new Error(`Blog entry not found: ${locale}/${slug}`);
}

const { Content } = await render(post);
const allPosts = await getLocalizedBlog(locale);
const recentPosts = allPosts.filter((p) => p.id !== post.id).slice(0, 4);
const { locale: contentLocale } = splitLocaleId(post.id);
const contentDir = getDirection(contentLocale);
---

<Layout
  title={t("blog:post.pageTitle", { title: post.data.title })}
  description={post.data.summary || post.data.title}
  openGraph={{
    basic: {
      title: post.data.title,
      type: "article",
      image: `/open-graph/blog/${slug}.png`,
    },
    image: {
      alt: `OpenGraph image for Monero blog post titled "${post.data.title}"`,
    },
    article: {
      publishedTime: new Date(getDateStringFromId(slug) ?? "").toISOString(),
      authors: post.data.author
        .split(/\s+and\s+|,/)
        .map((a: string) => a.trim()),
      tags: post.data.tags ?? [],
    },
  }}
>
  <link
    slot="head"
    rel="alternate"
    type="application/rss+xml"
    title="Monero Blog RSS"
    href={new URL("feed.xml", Astro.site)}
  />
  <div class="blog-container">
    <article class="blog-post">
      <BlogHeader
        title={post.data.title}
        id={slug}
        author={post.data.author}
        tags={post.data.tags}
      />
      {
        post.data.image && (
          <div style="text-align: center;">
            <Image
              src={post.data.image}
              alt=""
              width={350}
              layout="constrained"
              position="center"
              format="avif"
            />
          </div>
        )
      }
      <BlogContent lang={contentLocale} dir={contentDir}>
        <Content />
      </BlogContent>
    </article>

    <Card as="aside" border transparent class="sidebar">
      <h2>{t("blog:post.recentPosts")}</h2>
      <ul class="recent-posts">
        {
          recentPosts.map((recentPost) => {
            const { slug: recentSlug } = splitLocaleId(recentPost.id);
            const dateStr = getDateStringFromId(recentSlug);
            const formattedDate = localizeDateString(dateStr, {
              year: "numeric",
              month: "long",
              day: "numeric",
            });
            return (
              <li>
                <a
                  class="post-title"
                  href={localizeHref(`/blog/${recentSlug}/`)}
                >
                  {recentPost.data.title}
                </a>
                <time class="post-date" datetime={dateStr}>
                  {formattedDate}
                </time>
              </li>
            );
          })
        }
      </ul>
    </Card>
  </div>
</Layout>

<style>
  .blog-container {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);

    > * {
      min-width: 0;
    }
  }

  .sidebar {
    height: fit-content;

    & h2 {
      font-size: var(--font-size-xl);
      margin-top: 0;
    }
  }

  .recent-posts {
    list-style: none;
    padding: 0;
    margin-bottom: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);

    li {
      margin-bottom: var(--space-xs);
    }

    .post-title {
      font-size: var(--font-size-md);
      color: var(--paragraph-main);
      text-decoration-line: underline;
      text-decoration-style: dotted;

      &:hover {
        text-decoration: underline;
      }
    }

    .post-date {
      display: block;
      font-size: var(--font-size-sm);
      color: var(--paragraph-subtitle);
      margin-top: var(--space-2xs);
    }
  }

  @media (width >= 1200px) {
    .blog-container {
      grid-template-columns: 1fr 65ch 1fr;
    }

    .blog-post {
      grid-column: 2;
    }

    .sidebar {
      grid-column: 2;
      grid-row: 2;
    }
  }

  @media (width >= 1600px) {
    .sidebar {
      grid-column: 3;
      grid-row: 1;
    }
  }
</style>
