---
import BookCard from "@/components/pages/resources/library/BookCard.astro";
import Button from "@/components/ui/Button.astro";
import ExternalResourceButton from "@/components/ui/ExternalResourceButton.astro";
import HeroCard from "@/components/ui/HeroCard.astro";
import MaskIcon from "@/components/ui/icons/MaskIcon.astro";
import Grid from "@/components/ui/layout/Grid.astro";
import PageContainer from "@/components/ui/layout/PageContainer.astro";
import PageSection from "@/components/ui/layout/PageSection.astro";
import SectionTabs from "@/components/ui/tabs/SectionTabs.astro";
import TitleCard from "@/components/ui/TitleCard.astro";
import Layout from "@/layouts/Layout.astro";

import { books, cheatsheets, newsletters } from "@/data/resources/library";
import { icons } from "@/utils/icons";

const { dir, t, localizeHref } = Astro.locals;

const featured = books[0];
if (!featured || !featured.cover) {
  throw new Error(
    "Library: At least one book must exist and have a cover image.",
  );
}

const tabs = [
  {
    label: t("knowledge-base:library.sections.books.title"),
    count: books.length,
  },
  {
    label: t("knowledge-base:library.sections.cheatsheets.title"),
    count: cheatsheets.length,
  },
  {
    label: t("knowledge-base:library.sections.newsletters.title"),
    count: newsletters.length,
  },
];
---

<Layout
  title={t("knowledge-base:library.pageTitle")}
  description={t("knowledge-base:library.subtitle")}
>
  <TitleCard
    title={t("knowledge-base:library.title")}
    subtitle={t("knowledge-base:library.subtitle")}
    backHref={localizeHref("/resources/knowledge-base/")}
    backLabel={t("knowledge-base:index.title")}
  />

  <PageContainer>
    <HeroCard
      image={featured.cover}
      imageAlt={featured.coverAlt ?? ""}
      title={featured.subtitle
        ? `${featured.title} - ${featured.subtitle}`
        : featured.title}
      lead={t("knowledge-base:library.featured.lead")}
      description={featured.description}
    >
      <Button as="a" href={featured.link}>
        {t("knowledge-base:library.featured.readCta")}
        <MaskIcon
          src={icons.mask("arrow-right")}
          size="1em"
          rtl={dir === "rtl"}
        />
      </Button>
    </HeroCard>

    <PageSection>
      <SectionTabs tabs={tabs}>
        <Fragment slot="panel-0">
          <Grid columns={2} gap="md">
            {books.map((book) => <BookCard {...book} />)}
          </Grid>
        </Fragment>

        <Fragment slot="panel-1">
          <div class="salmon-intro">
            <h3>
              {
                t(
                  "knowledge-base:library.sections.cheatsheets.salmonSeries.title",
                )
              }
            </h3>
            <p>
              {
                t(
                  "knowledge-base:library.sections.cheatsheets.salmonSeries.description",
                )
              }
            </p>
          </div>
          <Grid minWidth="22rem" gap="md">
            {
              cheatsheets.map((sheet) => (
                <ExternalResourceButton
                  href={sheet.url}
                  title={sheet.title}
                  subtitle={sheet.description}
                  icon={icons.mask(sheet.icon)}
                />
              ))
            }
          </Grid>
        </Fragment>

        <Fragment slot="panel-2">
          <Grid minWidth="22rem" gap="md">
            {
              newsletters.map((newsletter) => (
                <ExternalResourceButton
                  href={newsletter.url}
                  title={newsletter.title}
                  subtitle={newsletter.description}
                />
              ))
            }
          </Grid>
        </Fragment>
      </SectionTabs>
    </PageSection>
  </PageContainer>
</Layout>

<style>
  .salmon-intro {
    margin-bottom: var(--space-xl);
  }

  .salmon-intro h3 {
    margin: 0 0 var(--space-2xs);
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-semibold);
    color: var(--heading-color);
  }

  .salmon-intro p {
    margin: 0;
    color: var(--paragraph-subtitle);
    max-width: 70ch;
    line-height: var(--line-height-body);
  }
</style>
