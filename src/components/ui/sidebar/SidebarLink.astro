---
import MaskIcon from "../icons/MaskIcon.astro";
import type { ImageMetadata } from "astro";

interface Props {
  href: string;
  icon: ImageMetadata;
  external?: boolean;
  class?: string;
}

const { href, icon, external = false, class: className, ...rest } = Astro.props;
---

<a
  href={href}
  class:list={["link", className]}
  target={external ? "_blank" : undefined}
  rel={external ? "noopener noreferrer" : undefined}
  {...rest}
>
  <span class="icon" aria-hidden="true">
    <MaskIcon src={icon} size="1.5em" />
  </span>
  <span class="title">
    <slot />
  </span>
</a>

<style>
  .link {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-sm) var(--space-md);
    background: var(--card-elevated-color);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
    transition: background 0.15s ease;

    &::after {
      display: none;
    }

    &:hover,
    &:focus-visible {
      background: var(--card-hover-color);
      text-decoration: none;
    }
  }

  .icon {
    flex-shrink: 0;
    color: var(--monero-orange);
    display: flex;
    align-items: center;
  }

  .title {
    flex: 1;
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-semibold);
    color: var(--heading-color);
    line-height: 1;
  }
</style>
